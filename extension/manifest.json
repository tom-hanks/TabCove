{
  "manifest_version": 3,
  "name": "TabCove",
  "version": "1.0.0",
  "description": "标签页管理专家 - 分组、休眠、收藏，让你的标签页井然有序。",
  "permissions": ["tabs", "activeTab", "storage", "power", "tabGroups"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "TabCove",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
